<Window x:Class="EncryptionDiary.Client.Windows.ServerManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Servers" Height="400" Width="500"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Server list -->
        <ListView Grid.Row="0" x:Name="lstServers" Margin="0,0,0,10">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Name" Width="150" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="URL" Width="200" DisplayMemberBinding="{Binding Url}"/>
                    <GridViewColumn Header="Username" Width="100" DisplayMemberBinding="{Binding Username}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Add new server -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,3"/>
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtName" Margin="0,3"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="URL:" VerticalAlignment="Center" Margin="0,3"/>
            <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtUrl" Margin="0,3"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="User:" VerticalAlignment="Center" Margin="0,3"/>
            <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtUsername" Margin="0,3"/>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Add Server" x:Name="btnAdd" Click="btnAdd_Click" 
                    Width="100" Margin="5" Padding="5,3"/>
            <Button Content="Remove Server" x:Name="btnRemove" Click="btnRemove_Click" 
                    Width="100" Margin="5" Padding="5,3"/>
            <Button Content="Test Connection" x:Name="btnTest" Click="btnTest_Click" 
                    Width="100" Margin="5" Padding="5,3"/>
        </StackPanel>
    </Grid>
</Window>